    "PriorityQueue": {
        "prefix": "!priorityqueue",
        "body": [
            "type Item struct {",
            "\tvalue int",
            "\tpriority int",
            "\tindex int",
            "}\n",
            "type PriorityQueue []*Item\n",
            "func (pq PriorityQueue) Len() int {",
            "\treturn len(pq)",
            "}\n",
            "func (pq PriorityQueue) Less(a, b int) bool {",
            "\t// Pop() should return the biggest - not lowest - priority;",
            "\t// so greater-than operator is used.",
            "\treturn pq[a].priority > pq[b].priority",
            "}\n",
            "func (pq PriorityQueue) Swap(a, b int) {",
            "\tpq[a], pq[b] = pq[b], pq[a]",
            "\tpq[a].index = a",
            "\tpq[b].index = b",
            "}\n",
            "func (pq *PriorityQueue) Push(x any) {",
            "\tl := len(*pq)",
            "\titem := x.(*Item)",
            "\titem.index = l",
            "\t*pq = append(*pq, item)",
            "}\n",
            "func (pq *PriorityQueue) Pop() any {",
            "\told := *pq",
            "\tl := len(old)",
            "\titem := old[l-1]",
            "\titem.index = -1 // just for safety",
            "\t*pq = old[0:l-1]",
            "\treturn item",
            "}\n",
            "// update() modifies the value and the priority of an Item already in the queue.",
            "func (pq *PriorityQueue) update(item *Item, value int, priority int) {",
            "\titem.value = value",
            "\titem.priority = priority",
            "\theap.Fix(pq, item.index)",
            "}"
        ],
        "description": "Simple priority-queue data structure. Not thread-safe!"
    },
