    "Stack": {
        "prefix": "Stack",
        "body": [
            "type ${1:Stack} []${2:int}\n",
            "func (s *$1) Push(val $2) {",
            "\t*s = append(*s, val)",
            "}\n",
            "func (s *$1) Pop() ($2, error) {",
            "\tsz := len(*s)",
            "\tif sz == 0 {",
            "\t\treturn 0, fmt.Errorf(\"Pop() from an empty $1.\")",
            "\t}",
            "\tval := (*s)[sz-1]",
            "\t*s = (*s)[:sz-1]",
            "\treturn val, nil",
            "}"
        ],
        "description": "Simple stack (LIFO) data structure. Not thread-safe!"
    }
